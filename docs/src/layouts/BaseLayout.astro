---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'ARC UI — Lit Web Components Library', description = 'A component library built on Lit Web Components. A custom code generator produces native bindings for React, Vue, Svelte, Angular, Solid, and Preact.' } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/og-image.png', Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#030307" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ARC UI" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <script is:inline>
      (function(){
        var t=localStorage.getItem('arc-theme')||'auto';
        document.documentElement.setAttribute('data-theme',t);
        document.addEventListener('astro:after-swap',function(){
          var t=localStorage.getItem('arc-theme')||'auto';
          document.documentElement.setAttribute('data-theme',t);
        });
      })();
    </script>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" href="/fonts/hostgrotesk-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link href="/fonts/fonts.css" rel="stylesheet" />
    {/* fallback="swap": browsers without the View Transitions API (Firefox)
        get an instant swap instead of Astro's simulated fade-out/fade-in,
        which reads as a full-page flicker. Native browsers still cross-fade. */}
    <ViewTransitions fallback="swap" />
    <script>
      import '@arclux/arc-ui/register';
      import '@arclux/brand/by';
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* Firefox's native view-transition cross-fade renders our glassy chrome
     (backdrop-filter top bar, shadow-DOM-heavy pages) as a visible flicker.
     -moz-appearance only matches in Firefox, so this skips the fade there —
     instant swaps — while Chrome/Safari keep the native cross-fade. */
  @supports (-moz-appearance: none) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation: none;
    }
  }
</style>
