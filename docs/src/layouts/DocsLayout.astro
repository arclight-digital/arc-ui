---
import BaseLayout from './BaseLayout.astro';
import SidebarNav from '../components/SidebarNav.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Wordmark from '../components/Wordmark.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteSearch from '../components/SiteSearch.astro';
import { ogPathFor } from '../lib/og-pages';
import fs from 'node:fs';
import '../styles/docs.css';

const pkg = JSON.parse(fs.readFileSync(new URL('../../../packages/web-components/package.json', import.meta.url), 'utf-8'));

interface Props {
  title: string;
  /** Full document title; overrides the default `${title} — ARC UI` pattern */
  htmlTitle?: string;
  description?: string;
  /** Site-relative OG image path; defaults to the page's card from og-pages.ts */
  ogImage?: string;
  activeSlug?: string;
  headings?: Array<{ id: string; label: string; level?: number }>;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  /** Set false on pages that emit their own TechArticle JSON-LD. */
  articleSchema?: boolean;
}

const {
  title,
  htmlTitle,
  description,
  ogImage = ogPathFor(Astro.url.pathname),
  activeSlug,
  headings = [],
  breadcrumbs = [],
  articleSchema = true,
} = Astro.props;

// Structured data for every docs page: breadcrumb trail (from the same prop
// that renders the visible breadcrumb) plus a default TechArticle for guide
// pages that don't emit a richer one themselves.
const canonicalPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const pageUrl = new URL(canonicalPath, Astro.site).href;
const trail = [
  { label: 'Docs', href: '/docs/getting-started' },
  ...breadcrumbs,
  ...(breadcrumbs.length ? [] : [{ label: title }]),
];
const docsJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: trail.map((c, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: c.label,
        ...(c.href ? { item: new URL(c.href, Astro.site).href } : {}),
      })),
    },
    ...(articleSchema
      ? [
          {
            '@type': 'TechArticle',
            headline: `${title} — ARC UI`,
            name: title,
            ...(description ? { description } : {}),
            url: pageUrl,
            image: new URL(ogImage, Astro.site).href,
            author: { '@id': 'https://arcui.dev/#org' },
            publisher: { '@id': 'https://arcui.dev/#org' },
            isPartOf: { '@id': 'https://arcui.dev/#website' },
          },
        ]
      : []),
  ],
};
---

<BaseLayout title={htmlTitle ?? `${title} — ARC UI`} description={description} ogImage={ogImage} ogType="article">
  <nav aria-label="Skip link">
    <arc-skip-link target="#main-content">Skip to content</arc-skip-link>
  </nav>
  <SiteSearch />
  <arc-app-shell>
    <!-- Top Bar -->
    <arc-top-bar slot="topbar" fixed nav-align="left" class="theme-fixed">
      <div slot="logo">
        <Wordmark />
      </div>
      <arc-navigation-menu slot="center">
        <arc-nav-item href="/docs/getting-started" active={!activeSlug || !['components', 'tokens', 'theme-synthesizer'].includes(activeSlug) && !Astro.url.pathname.startsWith('/docs/components') || undefined}>Docs</arc-nav-item>
        <arc-nav-item href="/docs/components" active={activeSlug === 'components' || Astro.url.pathname.startsWith('/docs/components') || undefined}>Components</arc-nav-item>
        <arc-nav-item href="/docs/tokens" active={activeSlug === 'tokens' || undefined}>Tokens</arc-nav-item>
        <arc-nav-item href="/docs/theme-synthesizer" active={activeSlug === 'theme-synthesizer' || undefined}>Synthesizer</arc-nav-item>
      </arc-navigation-menu>
      <div slot="actions" class="topbar-actions">
        <button
          type="button"
          class="topbar-search"
          data-site-search-trigger
          aria-label="Search docs"
          aria-keyshortcuts="Meta+K Control+K"
        >
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M11.5 7a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zm-.82 4.74a6 6 0 111.06-1.06l3.04 3.04a.75.75 0 11-1.06 1.06l-3.04-3.04z"/>
          </svg>
          <span class="topbar-search__text">Search</span>
          <kbd class="topbar-search__kbd" data-search-kbd>⌘K</kbd>
        </button>
        <arc-badge variant="primary" class="topbar-version">v{pkg.version}</arc-badge>
        <arc-theme-toggle icon-only></arc-theme-toggle>
        <arc-icon-button href="https://github.com/Arclight-Digital/arc-ui" name="github-logo" label="GitHub" variant="ghost" size="sm"></arc-icon-button>
      </div>
    </arc-top-bar>

    <!-- Sidebar -->
    <SidebarNav activeSlug={activeSlug} />

    <!-- Table of Contents -->
    <div slot="toc">
      {headings.length > 0 && (
        <TableOfContents headings={headings} />
      )}
    </div>

    <!-- Main Content -->
    <main id="main-content" class="docs-content" tabindex="-1">
      <slot />
    </main>
  </arc-app-shell>

  <SiteFooter />
  <arc-scroll-to-top></arc-scroll-to-top>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(docsJsonLd)} />
</BaseLayout>

<script>
  async function initNavigation() {
    const { navigate } = await import('astro:transitions/client');
    document.addEventListener('arc-navigate', (e: any) => {
      const href = e.detail?.href;
      if (href) {
        e.preventDefault();  // tell the component to suppress native <a> navigation
        navigate(href);      // use Astro view transitions instead
      }
    });
  }

  let _sidebarScrollTop = 0;

  function saveSidebarScroll() {
    const shell = document.querySelector('arc-app-shell');
    if (!shell || !shell.shadowRoot) return;
    const sidebarSlot = shell.shadowRoot.querySelector('.shell__sidebar');
    if (sidebarSlot) _sidebarScrollTop = sidebarSlot.scrollTop;
  }

  function restoreSidebarScroll() {
    requestAnimationFrame(() => {
      const shell = document.querySelector('arc-app-shell');
      if (!shell || !shell.shadowRoot) return;
      const sidebarSlot = shell.shadowRoot.querySelector('.shell__sidebar');
      if (sidebarSlot) sidebarSlot.scrollTop = _sidebarScrollTop;
    });
  }

  initNavigation();
  document.addEventListener('astro:page-load', initNavigation);
  document.addEventListener('astro:before-preparation', saveSidebarScroll);
  document.addEventListener('astro:after-swap', restoreSidebarScroll);
</script>

<style>
  .topbar-actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  /* ── Main content area ── */
  arc-app-shell::part(content) {
    position: relative;
  }

  .docs-content {
    contain: inline-size;
    outline: none;
    box-shadow: none;
  }

</style>
